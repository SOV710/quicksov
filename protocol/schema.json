                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "width": { "type": "number" },
                  "height": { "type": "number" }
                }
              }
            }
          },
          "response": { "type": "null" }
        }
      },
      "backend": "local directory scan plus qsov-wallpaperd supervision; output binding uses source/view model"
    },

    "theme": {
