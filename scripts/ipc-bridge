"""Bridge between quicksov daemon UDS (msgpack) and stdout/stdin (JSON lines)."""

import sys
import os
import socket
import struct
import json
import threading

try:
    import msgpack
except ImportError:
    sys.stderr.write("error: msgpack not installed; run: pip install msgpack\n")
    sys.exit(1)


def _read_frame(sock):
    header = b""
    while len(header) < 4:
        chunk = sock.recv(4 - len(header))
        if not chunk:
            raise EOFError("socket closed")
        header += chunk
    length = struct.unpack("<I", header)[0]
    data = b""
    while len(data) < length:
        chunk = sock.recv(length - len(data))
        if not chunk:
            raise EOFError("socket closed")
        data += chunk
    return data


def _send_frame(sock, msg):
    data = msgpack.packb(msg, use_bin_type=True)
    sock.sendall(struct.pack("<I", len(data)) + data)


def main():
    sock_path = sys.argv[1] if len(sys.argv) > 1 else os.path.join(
        os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"),
        "quicksov", "daemon.sock"
    )

    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        sock.connect(sock_path)
    except OSError as exc:
        sys.stderr.write(f"error: cannot connect to {sock_path}: {exc}\n")
        sys.exit(1)

    hello = {"proto_version": "qsov/1", "client_name": "quickshell", "client_version": "0.1.0"}
    _send_frame(sock, hello)

    ack_data = _read_frame(sock)
    ack = msgpack.unpackb(ack_data, raw=False)
    sys.stdout.write(json.dumps({"_type": "HelloAck", **ack}) + "\n")
    sys.stdout.flush()

    def reader():
        try:
            while True:
                frame = _read_frame(sock)
                msg = msgpack.unpackb(frame, raw=False)
                sys.stdout.write(json.dumps(msg) + "\n")
                sys.stdout.flush()
        except Exception:
            pass
        finally:
            os._exit(0)

    threading.Thread(target=reader, daemon=True).start()

    try:
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
                _send_frame(sock, msg)
            except (json.JSONDecodeError, OSError) as exc:
                sys.stderr.write(f"warn: {exc}\n")
    except (EOFError, KeyboardInterrupt):
        pass


if __name__ == "__main__":
    main()
